{
  "name": "@microsoft/bf-dialog",
  "version": "1.0.0",
  "author": "Microsoft",
  "bugs": "https://github.com/microsoft/botframework-cli/issues",
  "engines": {
    "node": ">=8.0.0"
  },
  "files": [
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json",
    "/templates"
  ],
  "homepage": "https://github.com/microsoft/botframework-cli",
  "keywords": [
    "oclif-plugin"
  ],
  "license": "MIT",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "bf",
    "devPlugins": [
      "@oclif/plugin-help"
    ]
  },
  "repository": "https://github.com/microsoft/botframework-cli/tree/master/packages/dialog",
  "scripts": {
    "postpack": "rimraf oclif.manifest.json",
    "prepack": "npm run clean && npm run build && npm run doc:readme",
    "posttest": "tslint -p test -t stylish",
    "build": "tsc -b",
    "clean": "rimraf ./.nyc_output ./lib ./package-lock.json ./tsconfig.tsbuildinfo",
    "test": "mocha",
    "coverage": "nyc npm run test",
    "doc": "npm run build && npm run doc:readme && rimraf oclif.manifest.json",
    "doc:readme": "oclif-dev manifest && oclif-dev readme",
    "version": "npm run doc:readme && git add README.md"
  },
  "dependencies": {
    "@microsoft/bf-cli-command": "~1.0.0",
    "@oclif/core": "~3.25.0",
    "@types/lru-cache": "^5.1.0",
    "@types/xml2js": "^0.4.4",
    "ajv": "^6.12.2",
    "axios": "~0.28.0",
    "https-proxy-agent": "^5.0.0",
    "chalk": "^2.4.2",
    "clone": "^2.1.2",
    "fs-extra": "^8.1.0",
    "globby": "^14.0.1",
    "@apidevtools/json-schema-ref-parser": "^9.0.1",
    "os": "~0.1.1",
    "path": "^0.12.7",
    "seedrandom": "~3.0.5",
    "semver": "^7.6.0",
    "tslib": "^2.0.3",
    "xml2js": "^0.4.19",
    "json-ptr": "~3.1.0",
    "json-schema-merge-allof": "~0.7.0",
    "@snyk/nuget-semver": "~1.3.0"
  },
  "devDependencies": {
    "@types/chai": "^4.2.0",
    "@types/fs-extra": "^8.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.27",
    "@types/seedrandom": "~2.4.28",
    "chai": "^5.1.0",
    "mocha": "^10.3.0",
    "nock": "^13.0.11",
    "nyc": "^15.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
