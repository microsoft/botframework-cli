{
  "name": "@microsoft/bf-orchestrator-cli",
  "description": "Bot Orchestrator",
  "version": "1.0.0",
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "ia32"
  ],
  "engines": {
    "node": "^10.0.0 || ^12.0.0 || ^13.0.0 || ^14.0.0"
  },
  "author": "Microsoft",
  "bugs": "https://github.com/microsoft/botframework-cli/issues",
  "dependencies": {
    "@microsoft/bf-cli-command": "1.0.0",
    "@oclif/core": "^3.25.0",
    "@oclif/plugin-help": "^2",
    "@types/fs-extra": "~8.1.0",
    "fs-extra": "~9.0.0",
    "read-text-file": "~1.1.0",
    "tslib": "^2.0.3",
    "@microsoft/bf-orchestrator": "1.0.0"
  },
  "devDependencies": {
    "@oclif/dev-cli": "^1.22.2",
    "@oclif/plugin-help": "^2.2.3",
    "@oclif/test": "^1.2.5",
    "@types/chai": "^4.2.9",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.27",
    "@types/sinon": "^9.0.4",
    "chai": "^5.1.0",
    "eslint": "^8.57.0",
    "eslint-config-oclif": "^5.1.1",
    "eslint-config-oclif-typescript": "^3.1.2",
    "globby": "^14.0.1",
    "mocha": "^10.3.0",
    "nyc": "^15.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "sinon": "^9.0.2"
  },
  "files": [
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json",
    "/yarn.lock"
  ],
  "homepage": "https://github.com/microsoft/botframework-cli",
  "keywords": [
    "oclif-plugin"
  ],
  "license": "MIT",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "bf",
    "devPlugins": [
      "@oclif/plugin-help"
    ]
  },
  "repository": "microsoft/botframework-cli",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "postpack": "rimraf oclif.manifest.json",
    "posttest": "eslint . --ext .ts --config .eslintrc",
    "prepack": "tsc -b && oclif-dev manifest",
    "build": "tsc -b",
    "clean": "rimraf ./.nyc_output ./package-lock.json ./tsconfig.tsbuildinfo",
    "test": "mocha",
    "coverage": "nyc npm run test",
    "report:coverage": "npm run coverage && nyc report --reporter=text-lcov | coveralls",
    "doc": "npm run build && npm run doc:readme && rimraf oclif.manifest.json",
    "doc:readme": "oclif-dev manifest && oclif-dev readme",
    "version": "npm run doc:readme && git add README.md"
  }
}
